# Copy to `.env.local` for local Next.js (see Vercel dashboard for production).

# MongoDB (Atlas or local) — required for auth + API routes that use the DB
MONGODB_URI=

# JWT signing — required (use a long random string in production)
JWT_SECRET=

# Optional
# JWT_EXPIRES_IN=7d
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
