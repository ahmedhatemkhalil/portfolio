# backend/.env — loaded after the repo root `.env` (see loadEnv.js).
# You can put MONGO_URI / MONGODB_URI only in the root `.env` if you prefer.
#
# Copy this file to .env in this folder (backend/.env)
# MongoDB Atlas: Database -> Connect -> Drivers -> copy connection string
# Replace <password> and set a database name (e.g. myapp)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority
# Alternative name (either works):
# MONGO_URI=mongodb+srv://...

# Strong random string (e.g. openssl rand -base64 32)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

# Optional in development: omit to allow any http(s)://localhost or 127.0.0.1 port.
# In production, set an explicit comma-separated list.
CORS_ORIGIN=http://localhost:3000
